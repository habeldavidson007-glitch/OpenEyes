```gitignore
# Python cache files
__pycache__/
*.pyc
*.pyo
*.pyd

# Test results
test_results/

# Environment files
.env
.env.local
*.env.*

# Dependencies
.venv/
venv/
node_modules/

# Logs and temporary files
*.log
*.tmp
*.swp

# Editors
.vscode/
.idea/

# Coverage reports
.coverage
htmlcov/
coverage/

# Build artifacts
dist/
build/
target/
*.class
*.o
*.obj
*.exe
*.dll
*.so
*.a
*.out
```