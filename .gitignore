```gitignore
# Python
__pycache__/
*.pyc
*.pyo
*.pyd

# Dependencies
.venv/
venv/
.env
.env.local
*.env.*

# Build artifacts
dist/
build/
*.egg-info/

# Logs and temporary files
*.log
*.tmp

# Editors
.vscode/
.idea/
*.swp
*.swo

# Coverage
.coverage
coverage/
htmlcov/

# Testing
.pytest_cache/
.mypy_cache/
```