  "archive_org_integration": {
    "purpose": "Historical legislative texts, defunct government websites, temporal context",
    "use_cases": [
      "Track evolution of electoral laws",
      "Recover superseded regulations",
      "Access defunct agency guidance",
      "Preserve institutional memory"
    ],
    "api_endpoint": "https://archive.org/help/wayback_api.php",
    "citation_format": "archive_url + capture_date"
  },
  "philosophy_guard": {
    "principle": "Describe what IS, not what SHOULD BE",
    "acceptable_verbs": ["is", "are", "requires", "prohibits", "established", "codified", "held", "ruled"],
    "rejected_verbs": ["should", "ought", "must", "needs to", "better", "worse"],
    "validation_questions": [
      "Does this describe an existing institution, process, or outcome?",
      "Can this be verified against primary sources?",
      "Would reasonable observers across the political spectrum agree this is factually accurate?",
      "If discussing debates, are multiple positions presented descriptively?"
    ]
  },
